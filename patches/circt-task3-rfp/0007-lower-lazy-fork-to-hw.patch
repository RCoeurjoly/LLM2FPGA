+// CHECK-LABEL: hw.module @handshake_lazy_fork_in_none_out_none_none_1ins_2outs_ctrl(
+// CHECK:         %[[IN_DATA:.*]], %[[IN_VALID:.*]] = esi.unwrap.vr %{{.*}}, %[[IN_READY:.*]] : i0
+// CHECK:         %[[OUT0:.*]], %[[OUT0_READY:.*]] = esi.wrap.vr %[[IN_DATA]], %[[OUT_VALID:.*]] : i0
+// CHECK:         %[[OUT1:.*]], %[[OUT1_READY:.*]] = esi.wrap.vr %[[IN_DATA]], %[[OUT_VALID]] : i0
+// CHECK:         %[[ALL_READY:.*]] = comb.and %[[OUT0_READY]], %[[OUT1_READY]] {sv.namehint = "allReady"} : i1
+// CHECK:         %[[OUT_VALID]] = comb.and %[[IN_VALID]], %[[ALL_READY]] : i1
+// CHECK:         hw.output %[[OUT0]], %[[OUT1]] : !esi.channel<i0>, !esi.channel<i0>
+
+handshake.func @test_lazy_fork(%arg0: none, %arg1: none, ...) -> (none, none, none) {
+  %0:2 = lazy_fork [2] %arg0 : none
