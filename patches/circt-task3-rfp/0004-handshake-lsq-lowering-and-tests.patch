+// RUN: circt-opt -handshake-materialize-forks-sinks -lower-handshake-to-hw -split-input-file %s | FileCheck %s
+
+// TinyStories-relevant LSQ memory shape: multiple logical accesses to one
+// memory should collapse to a single physical read and write port in HW.
+// CHECK-LABEL: hw.module @handshake_memory_out_ui64_id0(
+// CHECK: %[[MEM:.*]] = seq.hlmem @_handshake_memory_0 %clock, %reset : <50257xi64>
+// CHECK: seq.read %[[MEM]]
+// CHECK-NOT: seq.read %[[MEM]]
+// CHECK: seq.write %[[MEM]]
+// CHECK-NOT: seq.write %[[MEM]]
+// CHECK: hw.output
+handshake.func @main(%ctrl0 : none, %ctrl1 : none, %addr0 : index, %addr1 : index, %data0 : i64, %data1 : i64) -> none {
+  %m:6 = memory[ld = 2, st = 2](%ctrl0, %ctrl1, %data0, %addr0, %data1, %addr1, %addr0, %addr1) {id = 0 : i32, lsq = true} : memref<50257xi64>, (none, none, i64, index, i64, index, index, index) -> (i64, i64, none, none, none, none)
+  sink %m#0 : i64
+  sink %m#1 : i64
+  %done0 = join %m#2, %m#3 : none, none
+  %done1 = join %m#4, %m#5 : none, none
+  %done = join %done0, %done1 : none, none
+  return %done : none
+}
